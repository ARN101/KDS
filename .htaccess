<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Send empty requests to the public folder
    RewriteRule ^$ public/ [L]
    
    # Send everything else to the public folder if it isn't seeking a direct root file
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
